# syntax=docker/dockerfile:1
# ── Dockerfile.agent-worker ──────────────────────────────────────
# Multi-stage production build for @agentctl/agent-worker.
#
# Build context must be the monorepo root:
#   docker build -f infra/docker/Dockerfile.agent-worker -t agentctl-agent-worker .
#
# Security notes:
#   - Runs as non-root user (uid 1001)
#   - Use cap_drop: [ALL] in docker-compose
#   - No secrets baked in — pass via environment variables
#   - Final image omits git; worker degrades gracefully when git UX is unavailable
# ─────────────────────────────────────────────────────────────────

# Keep the worker on a glibc-based slim image, but use the newer Debian
# suite so the shipped OS package set can pick up newer security fixes.
ARG NODE_IMAGE=node:22.22.1-trixie-slim

# ── Stage 1: Build ──────────────────────────────────────────────
FROM ${NODE_IMAGE} AS build

ARG PNPM_VERSION=8.15.4

# Install pnpm + native compilation tools for node-pty.
# Debian trixie drops distutils from the default Python stdlib, so
# node-gyp also needs python3-setuptools for the compatibility shim.
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3 python3-setuptools make g++ && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── Layer 1: dependency manifests (changes rarely) ──────────────
# Copying manifests first means Docker can cache the install step
# whenever only source code changes.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/tsconfig.json packages/shared/
COPY packages/agent-worker/package.json packages/agent-worker/tsconfig.json packages/agent-worker/

# ── Layer 2: install with BuildKit cache mount ──────────────────
# --mount=type=cache persists the pnpm content-addressable store across
# builds so unchanged packages are never re-downloaded.
RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# ── Layer 3: source code (changes most often) ──────────────────
COPY packages/shared/src/ packages/shared/src/
COPY packages/shared/scripts/ packages/shared/scripts/
COPY packages/agent-worker/src/ packages/agent-worker/src/

# Build shared first, then agent-worker (pnpm -r respects dependency order)
RUN pnpm -r build

# ── Stage 1b: Production dependencies only ─────────────────────
# A separate stage so the prod install is also cache-mountable and
# does not invalidate when source code changes.
FROM ${NODE_IMAGE} AS deps

ARG PNPM_VERSION=8.15.4
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate

# node-pty requires native compilation tools, and node-gyp on Debian
# trixie still expects the distutils shim from python3-setuptools.
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3 python3-setuptools make g++ && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json packages/shared/
COPY packages/agent-worker/package.json packages/agent-worker/

RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --prod

# ── Stage 2: Production ────────────────────────────────────────
FROM ${NODE_IMAGE} AS production

# Labels for container metadata
LABEL org.opencontainers.image.title="agentctl-agent-worker" \
      org.opencontainers.image.description="AgentCTL Agent Worker — per-machine agent daemon" \
      org.opencontainers.image.source="https://github.com/agentctl/agentctl" \
      security.cap-drop="ALL"

# Install runtime dependencies and remove package-manager tooling from the final image.
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get upgrade -y && \
    rm -rf /usr/local/lib/node_modules/npm /usr/local/lib/node_modules/corepack && \
    rm -f /usr/local/bin/npm /usr/local/bin/npx /usr/local/bin/corepack && \
    groupadd --gid 1001 agentctl && \
    useradd --uid 1001 --gid 1001 --create-home --home-dir /home/agentctl --shell /usr/sbin/nologin agentctl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy built artifacts from the build stage
COPY --from=build --chown=agentctl:agentctl /app/packages/shared/dist/ packages/shared/dist/
COPY --from=build --chown=agentctl:agentctl /app/packages/shared/package.json packages/shared/
COPY --from=build --chown=agentctl:agentctl /app/packages/agent-worker/dist/ packages/agent-worker/dist/
COPY --from=build --chown=agentctl:agentctl /app/packages/agent-worker/package.json packages/agent-worker/

# Copy production-only node_modules from the deps stage
COPY --from=deps --chown=agentctl:agentctl /app/node_modules/ node_modules/
COPY --from=deps --chown=agentctl:agentctl /app/packages/shared/node_modules/ packages/shared/node_modules/
COPY --from=deps --chown=agentctl:agentctl /app/packages/agent-worker/node_modules/ packages/agent-worker/node_modules/

# Copy root package.json and workspace config (needed for pnpm workspace resolution)
COPY --from=deps --chown=agentctl:agentctl /app/package.json /app/pnpm-workspace.yaml ./

# Create workspace directory for git worktrees (owned by agentctl)
RUN mkdir -p /workspace && chown agentctl:agentctl /workspace

ENV NODE_ENV=production
ENV PORT=9000

# Switch to non-root user
USER agentctl

EXPOSE 9000

# Healthcheck: agent-worker exposes GET /health on port 9000
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD ["node", "-e", "const port = process.env.PORT || 9000; fetch('http://127.0.0.1:' + port + '/health', { signal: AbortSignal.timeout(4000) }).then((res) => process.exit(res.ok ? 0 : 1)).catch(() => process.exit(1));"]

CMD ["node", "packages/agent-worker/dist/index.js"]
