{
  "name": "@agentctl/mobile",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "build": "pnpm --filter @agentctl/shared build && tsc",
    "dev": "tsc --watch",
    "test": "pnpm --filter @agentctl/shared build && vitest run",
    "test:coverage": "pnpm --filter @agentctl/shared build && vitest run --coverage",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@agentctl/shared": "workspace:*",
    "expo": "^55.0.8",
    "expo-constants": "^55.0.9",
    "expo-notifications": "^55.0.13"
  },
  "devDependencies": {
    "@react-navigation/bottom-tabs": "^7.15.3",
    "@react-navigation/native": "^7.1.31",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^3.2.4",
    "react": "^19.2.4",
    "react-native": "^0.84.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
