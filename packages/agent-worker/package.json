{
  "name": "@agentctl/agent-worker",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @agentctl/shared build && tsc",
    "start": "node dist/index.js",
    "test": "pnpm --filter @agentctl/shared build && vitest run",
    "test:coverage": "pnpm --filter @agentctl/shared build && vitest run --coverage",
    "postinstall": "node -e \"const p=require('path'),f=require('fs'),d=p.join(__dirname,'node_modules','node-pty','prebuilds');if(f.existsSync(d)){for(const a of f.readdirSync(d)){const h=p.join(d,a,'spawn-helper');if(f.existsSync(h))f.chmodSync(h,0o755)}}\""
  },
  "dependencies": {
    "@agentctl/shared": "workspace:*",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.8.1",
    "node-pty": "^1.1.0",
    "pino": "^9.6.0",
    "smol-toml": "^1.6.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.51"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
