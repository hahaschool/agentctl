# AgentCTL Environment Template
# Copy this file to .env.{tier} and fill in values.
# See docs/plans/2026-03-12-dev-environment-cd-strategy.md for details.

# ── Tier Identification ────────────────────────────────────────
TIER=                          # Required: beta, dev-1, dev-2, etc.

# ── Control Plane ──────────────────────────────────────────────
PORT=8080                      # Fastify listen port
HOST=0.0.0.0                   # Bind address
DATABASE_URL=                  # PostgreSQL connection string (per-tier DB)
REDIS_URL=                     # Redis URL with DB number (e.g. redis://localhost:6379/1)
LOG_LEVEL=info                 # pino log level

# ── Agent Worker ───────────────────────────────────────────────
WORKER_PORT=9000               # Worker listen port
MACHINE_ID=                    # Unique machine identifier
CONTROL_PLANE_URL=             # CP URL for health/audit (must match PORT above)
CONTROL_URL=                   # Alias for CONTROL_PLANE_URL

# ── Web App ────────────────────────────────────────────────────
WEB_PORT=5173                  # Next.js listen port
NEXT_PUBLIC_API_URL=           # CP URL for API rewrites (must match PORT above)
NEXT_PUBLIC_WS_URL=            # CP URL for WebSocket (ws:// protocol, same host:port as CP)

# ── Security ───────────────────────────────────────────────────
CREDENTIAL_ENCRYPTION_KEY=     # 64-char hex key for account credential encryption

# ── Observability ──────────────────────────────────────────────
LOG_DIR=./logs/beta            # Per-tier log directory
TIER_LABEL=                    # Tag for structured logs (should match TIER)
NODE_ENV=development           # Node environment
