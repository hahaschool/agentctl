# AgentCTL — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is gitignored by default.
# Each machine in the fleet needs its own .env with appropriate values.
#
# Variables marked [REQUIRED] must be set for production Docker deployments.
# Variables marked [optional] have sensible defaults or enable optional features.
# The docker-preflight.sh script validates all required vars before startup.


# ── Control Plane (packages/control-plane) ─────────────────────────────

# [optional] Server port for the control plane API — REST + WebSocket (default: 8080)
PORT=8080

# [optional] Bind address for the control plane server (default: 0.0.0.0)
HOST=0.0.0.0

# [REQUIRED] PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Omit to fall back to an in-memory registry (dev only — NOT for production).
DATABASE_URL=postgresql://agentctl:agentctl@localhost:5432/agentctl

# [REQUIRED] Redis connection URL — used by BullMQ task queue and LiteLLM cache.
# Must be a valid redis:// or rediss:// URL.
REDIS_URL=redis://localhost:6379

# [optional] LiteLLM proxy URL for multi-provider LLM routing.
# Leave empty to disable LLM router routes.
LITELLM_URL=http://localhost:4000

# [optional] Mem0 server URL for cross-device memory injection.
# Leave empty to disable memory injection.
MEM0_URL=http://localhost:8050

# [optional] Public URL of the control plane (used by task workers to call back).
# Defaults to http://<HOST>:<PORT> when unset.
CONTROL_PLANE_URL=http://localhost:8080

# [optional] Number of concurrent BullMQ task-worker jobs (default: 5)
WORKER_CONCURRENCY=5

# [optional] Log level: fatal, error, warn, info, debug, trace, silent (default: info)
LOG_LEVEL=info


# ── Agent Worker (packages/agent-worker) ───────────────────────────────

# [optional] Worker API port — agent management HTTP endpoints (default: 9000)
WORKER_PORT=9000

# [optional] Bind address for the worker server (default: 0.0.0.0)
WORKER_HOST=0.0.0.0

# [optional] Control plane URL that the worker reports health/audit to.
# Use Tailscale MagicDNS hostname in production (e.g. http://control:8080).
CONTROL_URL=http://localhost:8080

# [REQUIRED per machine] Unique machine identifier — MUST be different on each machine.
# Examples: machine-mac-mini-01, machine-ec2-us-east-1a, machine-laptop-dev
# Defaults to machine-<hostname> when unset.
MACHINE_ID=machine-my-mac

# [optional] Max concurrent agent instances on this machine (default: 3)
MAX_CONCURRENT_AGENTS=3

# [optional] Audit log output directory — NDJSON files written here daily (default: .agentctl/audit)
AUDIT_LOG_DIR=.agentctl/audit

# [optional] Filesystem IPC directory for NanoClaw-style JSON message passing (default: .agentctl/ipc)
IPC_DIR=.agentctl/ipc

# [optional] Root project path for git worktree isolation.
# Leave empty to run agents without worktree isolation.
PROJECT_PATH=/path/to/project

# [optional] Tailscale IPv4 address override.
# When unset the worker auto-detects via `tailscale ip -4`.
# Falls back to 127.0.0.1 if Tailscale is unavailable.
TAILSCALE_IP=

# [optional] Run ID linking this worker session to a control-plane run.
# When empty, audit reporting to the control plane is disabled.
RUN_ID=

# [optional] How often (ms) the audit reporter flushes buffered events (default: 5000)
AUDIT_FLUSH_INTERVAL_MS=5000

# [optional] Heartbeat interval to control plane in ms (default: 15000)
HEARTBEAT_INTERVAL_MS=15000

# [optional] Agent execution timeout in ms — kill if stuck (default: 3600000 = 1 hour)
AGENT_TIMEOUT_MS=3600000

# [optional] Max auto-restarts per agent before giving up (default: 3)
AGENT_MAX_RESTARTS=3

# [optional] Base directory for agent worktrees — used by PM2 worker config (default: /opt/agentctl/.trees)
WORKTREE_BASE_DIR=/opt/agentctl/.trees


# ── Redis (shared infrastructure) ─────────────────────────────────────

# Host and port used separately by LiteLLM Docker config for cache.
# These are internal Docker network references when using docker-compose.
REDIS_HOST=localhost
REDIS_PORT=6379


# ── LLM Providers: Anthropic ──────────────────────────────────────────
# Two org keys double effective rate limits via LiteLLM load balancing.

# [REQUIRED for LLM] Anthropic API key — Organization 1.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_KEY_ORG1=sk-ant-api03-REPLACE_WITH_YOUR_KEY_ORG1

# [optional] Anthropic API key — Organization 2 (for rate limit multiplication).
ANTHROPIC_KEY_ORG2=sk-ant-api03-REPLACE_WITH_YOUR_KEY_ORG2

# [optional] Direct Anthropic key for Claude Agent SDK on worker machines.
# Used by the Claude Code CLI subprocess. Set on machines that call Anthropic directly.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY


# ── LLM Providers: AWS Bedrock (Failover) ─────────────────────────────
# First failover when Anthropic Direct is rate-limited.
# Leave empty to use the default AWS credential chain (~/.aws/credentials, instance role).

# [optional] AWS access key ID
AWS_ACCESS_KEY_ID=

# [optional] AWS secret access key
AWS_SECRET_ACCESS_KEY=

# [optional] AWS region for Bedrock (default: us-east-1)
AWS_DEFAULT_REGION=us-east-1


# ── LLM Providers: Google Vertex AI (Failover) ────────────────────────
# Second failover. Requires a GCP project with Vertex AI enabled.

# [optional] GCP project ID for Vertex AI Claude deployments
GCP_PROJECT=your-gcp-project-id

# [optional] Path to GCP service account JSON key file.
# NEVER commit this file — keep it in a secure location on the machine.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json


# ── LiteLLM Proxy (infra/litellm) ─────────────────────────────────────

# [optional] Alias used by PM2 worker config — same as LITELLM_URL
LITELLM_PROXY_URL=http://localhost:4000

# [optional] Master key for LiteLLM admin API (generate a random string).
# Used for: creating virtual keys, viewing spend, managing models.
LITELLM_MASTER_KEY=sk-REPLACE_WITH_RANDOM_STRING


# ── Docker Compose: PostgreSQL Container ──────────────────────────────
# These are used by docker-compose.prod.yml to configure the PostgreSQL container.

# [optional] PostgreSQL user for the Docker container (default: agentctl)
POSTGRES_USER=agentctl

# [REQUIRED for Docker prod] PostgreSQL password for the Docker container.
# docker-compose.prod.yml will refuse to start if this is not set.
POSTGRES_PASSWORD=change-me-in-production

# [optional] PostgreSQL database name for the Docker container (default: agentctl)
POSTGRES_DB=agentctl


# ── Docker Compose: Port Mappings ─────────────────────────────────────
# Host port mappings for docker-compose. Override to avoid port conflicts.

# [optional] Host port for the control plane container (default: 8080)
CONTROL_PLANE_PORT=8080

# [optional] Host port for the agent worker container (default: 9000)
AGENT_WORKER_PORT=9000


# ── Security ──────────────────────────────────────────────────────────

# [optional] E2E encryption key for iOS <-> control plane communication.
# Generate with: npx tweetnacl-util@latest
# This is a base64-encoded 32-byte secret key.
E2E_SECRET_KEY=

# [optional] JWT secret for API authentication (generate a random 64-char string)
JWT_SECRET=

# [optional] Node environment: development, production, test (default: development)
NODE_ENV=development
