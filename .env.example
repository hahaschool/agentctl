# AgentCTL — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is gitignored by default.
# Each machine in the fleet needs its own .env with appropriate values.


# =====================================================================
# CONTROL PLANE  (packages/control-plane)
# =====================================================================

# Server port for the control plane API (REST + WebSocket)
PORT=8080

# Bind address for the control plane server
HOST=0.0.0.0

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Leave empty to fall back to an in-memory registry (dev only).
DATABASE_URL=postgresql://agentctl:agentctl@localhost:5432/agentctl

# Redis connection URL (used by BullMQ task queue)
REDIS_URL=redis://localhost:6379

# LiteLLM proxy URL for multi-provider LLM routing
# Leave empty to disable LLM router routes.
LITELLM_URL=http://localhost:4000

# Mem0 server URL for cross-device memory
# Leave empty to disable memory injection.
MEM0_URL=http://localhost:8050

# Public URL of the control plane (used by task workers to call back).
# Defaults to http://<HOST>:<PORT> when unset.
CONTROL_PLANE_URL=http://localhost:8080

# Number of concurrent BullMQ task-worker jobs
WORKER_CONCURRENCY=5

# Log level: error, warn, info, debug
LOG_LEVEL=info


# =====================================================================
# AGENT WORKER  (packages/agent-worker)
# =====================================================================

# Worker API port (agent management HTTP endpoints)
WORKER_PORT=9000

# Bind address for the worker server
WORKER_HOST=0.0.0.0

# Control plane URL that the worker reports health/audit to.
# Use Tailscale MagicDNS hostname in production (e.g. http://control:8080).
CONTROL_URL=http://localhost:8080

# Unique machine identifier -- MUST be different on each machine.
# Examples: machine-mac-mini-01, machine-ec2-us-east-1a, machine-laptop-dev
# Defaults to machine-<hostname> when unset.
MACHINE_ID=machine-my-mac

# Max concurrent agent instances on this machine
MAX_CONCURRENT_AGENTS=3

# Audit log output directory (NDJSON files written here daily)
AUDIT_LOG_DIR=.agentctl/audit

# Filesystem IPC directory for NanoClaw-style JSON message passing
IPC_DIR=.agentctl/ipc

# Root project path for git worktree isolation.
# Leave empty to run agents without worktree isolation.
PROJECT_PATH=/path/to/project

# Tailscale IPv4 address override.
# When unset the worker auto-detects via `tailscale ip -4`.
# Falls back to 127.0.0.1 if Tailscale is unavailable.
TAILSCALE_IP=

# Run ID linking this worker session to a control-plane run.
# When empty, audit reporting to the control plane is disabled.
RUN_ID=

# How often (ms) the audit reporter flushes buffered events to the control plane
AUDIT_FLUSH_INTERVAL_MS=5000


# =====================================================================
# REDIS  (shared infrastructure)
# =====================================================================

# Host and port used separately by LiteLLM Docker config
REDIS_HOST=localhost
REDIS_PORT=6379


# =====================================================================
# LLM PROVIDERS -- Anthropic
# =====================================================================
# Two org keys double effective rate limits via LiteLLM load balancing.

# Anthropic API key -- Organization 1
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_KEY_ORG1=sk-ant-api03-REPLACE_WITH_YOUR_KEY_ORG1

# Anthropic API key -- Organization 2 (optional, for rate limit multiplication)
ANTHROPIC_KEY_ORG2=sk-ant-api03-REPLACE_WITH_YOUR_KEY_ORG2

# Direct Anthropic key for Claude Agent SDK (worker machines).
# This is used by the Claude Code CLI subprocess.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY


# =====================================================================
# LLM PROVIDERS -- AWS Bedrock (Failover)
# =====================================================================
# Used as first failover when Anthropic Direct is rate-limited.
# Leave empty to use the default AWS credential chain (~/.aws/credentials).

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1


# =====================================================================
# LLM PROVIDERS -- Google Vertex AI (Failover)
# =====================================================================
# Used as second failover. Requires a GCP project with Vertex AI enabled.

# GCP project ID
GCP_PROJECT=your-gcp-project-id

# Path to GCP service account JSON key file.
# NEVER commit this file -- keep it in a secure location on the machine.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json


# =====================================================================
# LiteLLM PROXY  (infra/litellm)
# =====================================================================

# Master key for LiteLLM admin API (generate a random string).
# Used for: creating virtual keys, viewing spend, managing models.
LITELLM_MASTER_KEY=sk-REPLACE_WITH_RANDOM_STRING


# =====================================================================
# SECURITY
# =====================================================================

# E2E encryption key for iOS <-> control plane communication.
# Generate with: npx tweetnacl-util@latest
# This is a base64-encoded 32-byte secret key.
E2E_SECRET_KEY=

# JWT secret for API authentication (generate a random 64-char string)
JWT_SECRET=

# Node environment: development, production
NODE_ENV=development
