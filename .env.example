# AgentCTL — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is gitignored by default.
# Each machine in the fleet needs its own .env with appropriate values.


# ═══════════════════════════════════════════════════════════════════
# CONTROL PLANE
# ═══════════════════════════════════════════════════════════════════

# Server port for the control plane API (REST + WebSocket)
PORT=8080

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Node environment: development, production
NODE_ENV=development


# ═══════════════════════════════════════════════════════════════════
# DATABASE — PostgreSQL
# ═══════════════════════════════════════════════════════════════════

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://agentctl:agentctl@localhost:5432/agentctl


# ═══════════════════════════════════════════════════════════════════
# REDIS — BullMQ Task Queue + LiteLLM Cache
# ═══════════════════════════════════════════════════════════════════

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Redis host/port (used separately by LiteLLM config)
REDIS_HOST=localhost
REDIS_PORT=6379


# ═══════════════════════════════════════════════════════════════════
# WORKER
# ═══════════════════════════════════════════════════════════════════

# Unique machine identifier — MUST be different on each machine.
# Examples: mac-mini-01, ec2-us-east-1a, laptop-dev
MACHINE_ID=dev-laptop

# Worker API port (agent management)
WORKER_PORT=9000

# Prometheus metrics endpoint port
METRICS_PORT=9090

# SSE agent output stream port
SSE_PORT=9100

# Control plane URL (use Tailscale MagicDNS hostname in production)
CONTROL_URL=http://localhost:8080

# Max concurrent agent instances on this machine
MAX_CONCURRENT_AGENTS=3

# Heartbeat interval to control plane (milliseconds)
HEARTBEAT_INTERVAL_MS=15000

# Agent execution timeout (milliseconds) — 1 hour default
AGENT_TIMEOUT_MS=3600000

# Base directory for git worktrees
WORKTREE_BASE_DIR=./.trees

# Audit log output directory
AUDIT_LOG_DIR=./logs


# ═══════════════════════════════════════════════════════════════════
# LLM PROVIDERS — Anthropic
# ═══════════════════════════════════════════════════════════════════
# Two org keys double effective rate limits via LiteLLM load balancing.

# Anthropic API key — Organization 1
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_KEY_ORG1=sk-ant-api03-REPLACE_WITH_YOUR_KEY_ORG1

# Anthropic API key — Organization 2 (optional, for rate limit multiplication)
ANTHROPIC_KEY_ORG2=sk-ant-api03-REPLACE_WITH_YOUR_KEY_ORG2

# Direct Anthropic key for Claude Agent SDK (worker machines)
# This is used by the Claude Code CLI subprocess.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY


# ═══════════════════════════════════════════════════════════════════
# LLM PROVIDERS — AWS Bedrock (Failover)
# ═══════════════════════════════════════════════════════════════════
# Used as first failover when Anthropic Direct is rate-limited.
# Leave empty to use the default AWS credential chain (~/.aws/credentials).

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1


# ═══════════════════════════════════════════════════════════════════
# LLM PROVIDERS — Google Vertex AI (Failover)
# ═══════════════════════════════════════════════════════════════════
# Used as second failover. Requires a GCP project with Vertex AI enabled.

# GCP project ID
GCP_PROJECT=your-gcp-project-id

# Path to GCP service account JSON key file
# NEVER commit this file — keep it in a secure location on the machine.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json


# ═══════════════════════════════════════════════════════════════════
# LiteLLM PROXY
# ═══════════════════════════════════════════════════════════════════

# URL of the LiteLLM proxy (local Docker or remote via Tailscale)
LITELLM_PROXY_URL=http://localhost:4000

# Master key for LiteLLM admin API (generate a random string)
# Used for: creating virtual keys, viewing spend, managing models
LITELLM_MASTER_KEY=sk-REPLACE_WITH_RANDOM_STRING


# ═══════════════════════════════════════════════════════════════════
# MEMORY — Mem0
# ═══════════════════════════════════════════════════════════════════

# Mem0 server URL (self-hosted Docker container)
MEM0_URL=http://localhost:8000


# ═══════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════

# E2E encryption key for iOS ↔ control plane communication
# Generate with: npx tweetnacl-util@latest
# This is a base64-encoded 32-byte secret key.
E2E_SECRET_KEY=

# JWT secret for API authentication (generate a random 64-char string)
JWT_SECRET=
